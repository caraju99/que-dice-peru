# Base de datos
# Por defecto SQLite (archivo local, no requiere instalar nada)
DATABASE_URL="file:./dev.db"

# Para usar PostgreSQL en producción, cambia el provider en prisma/schema.prisma
# a "postgresql" y usa algo como:
# DATABASE_URL="postgresql://usuario:password@host:5432/quedicePeru"

# NextAuth
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# Login con Google (opcional)
# Crea credenciales en https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
